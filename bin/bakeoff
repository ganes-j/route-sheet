#!/usr/bin/env python3
"""bakeoff — detached bake-off runner over llocal-native single-shot shapes.

Thin CLI wrapper. All deterministic logic lives in the importable
``bakeoff_grading`` module (mirrors the ``route_pick.py`` import precedent);
this file only wires the injectable callables to real resources — ``llocal``
for challenger runs, a subprocess for the bundle's verify commands, and a
local judge model for the pairwise margin.

  bakeoff run BUNDLE_DIR [--ledger PATH] [--challengers m1,m2]
       [--judge-model MODEL] [--detach]
  bakeoff --sweep MANIFEST_GLOB [...]     # U10, added later

The runner is single-shot only (batch-extraction / vision-OCR — shapes llocal
already runs); implementation-unit replay is gated behind the U9 harness spike.
A live interactive session pins concurrency to 1 so the runner never contends
with the user's Ollama use.
"""

import argparse
import importlib.util
import json
import os
import subprocess
import sys
import time
from pathlib import Path


def _load_sibling(name):
    path = Path(__file__).with_name(f"{name}.py")
    spec = importlib.util.spec_from_file_location(name, path)
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


grading = _load_sibling("bakeoff_grading")

LLOCAL = Path(__file__).with_name("llocal")
DEFAULT_LEDGER = Path("~/.claude/router-field-records.jsonl").expanduser()


def _log(runner_log):
    def emit(msg):
        line = f"{time.strftime('%Y-%m-%dT%H:%M:%S')} {msg}"
        print(line, file=sys.stderr)
        if runner_log is not None:
            with open(runner_log, "a", encoding="utf-8") as handle:
                handle.write(line + "\n")

    return emit


def _live_session_active():
    """Best-effort: a recently-touched Claude session file signals a live
    session. Absence of the signal defaults to NOT live (full concurrency)."""
    marker = Path("~/.claude/.session-active").expanduser()
    if marker.exists():
        return (time.time() - marker.stat().st_mtime) < 900
    return False


def _installed_local_models():
    try:
        out = subprocess.run(
            [sys.executable, str(LLOCAL), "models", "--names"],
            capture_output=True, text=True, timeout=30, check=True,
        )
    except (subprocess.SubprocessError, OSError):
        return []
    return [ln.strip() for ln in out.stdout.splitlines() if ln.strip()]


def _make_run_fn(log):
    def run_fn(executor, bundle_meta):
        model = executor.split(":", 1)[1] if ":" in executor else executor
        prompt = bundle_meta.get("task_prompt") or bundle_meta.get("spec", "")
        try:
            out = subprocess.run(
                [sys.executable, str(LLOCAL), "run", model, prompt],
                capture_output=True, text=True, timeout=600, check=True,
            )
            return out.stdout
        except (subprocess.SubprocessError, OSError) as exc:
            log(f"run_fn error for {executor}: {exc}")
            return ""

    return run_fn


def _make_verify_fn(bundle_dir, log):
    def verify_fn(challenger_output, verify_commands):
        if not verify_commands:
            return False
        (bundle_dir / "challenger_output.txt").write_text(
            challenger_output, encoding="utf-8"
        )
        for cmd in verify_commands:
            try:
                result = subprocess.run(
                    cmd, shell=True, cwd=bundle_dir,
                    capture_output=True, text=True, timeout=600,
                )
            except (subprocess.SubprocessError, OSError) as exc:
                log(f"verify error: {exc}")
                return False
            if result.returncode != 0:
                return False
        return True

    return verify_fn


def _make_judge_fn(judge_model, log):
    def judge_fn(prompt):
        try:
            out = subprocess.run(
                [sys.executable, str(LLOCAL), "run", judge_model, prompt,
                 "--json", "json"],
                capture_output=True, text=True, timeout=600, check=True,
            )
            return json.loads(out.stdout)
        except (subprocess.SubprocessError, OSError, json.JSONDecodeError) as exc:
            log(f"judge error: {exc}")
            return None

    judge_fn.model_tag = judge_model
    return judge_fn


def _detach():
    """Re-exec detached (new session) so the run survives coordinator exit."""
    if os.environ.get("_BAKEOFF_DETACHED") == "1":
        return
    os.environ["_BAKEOFF_DETACHED"] = "1"
    argv = [a for a in sys.argv if a != "--detach"]
    subprocess.Popen(
        [sys.executable] + argv,
        start_new_session=True,
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    sys.exit(0)


def cmd_run(args):
    if args.detach:
        _detach()

    bundle_dir = Path(args.bundle_dir).expanduser()
    meta_path = bundle_dir / "meta.json"
    if not meta_path.exists():
        print(f"no meta.json in {bundle_dir}", file=sys.stderr)
        return 2
    meta = json.loads(meta_path.read_text(encoding="utf-8"))
    spec = (bundle_dir / "spec.md").read_text(encoding="utf-8") if (
        bundle_dir / "spec.md"
    ).exists() else ""
    first_shot = None
    if (bundle_dir / "first_shot.patch").exists():
        first_shot = (bundle_dir / "first_shot.patch").read_text(encoding="utf-8")

    log = _log(args.runner_log or (bundle_dir / "runner.log"))

    if args.challengers:
        candidates = [
            c if c.startswith("llocal") else f"llocal:{c}"
            for c in args.challengers.split(",")
        ]
    else:
        candidates = [f"llocal:{m}" for m in _installed_local_models()]

    unit = {
        "unit_ref": meta.get("unit_ref", bundle_dir.name),
        "executor": "codex-implementer",
        "shape": args.shape,
        "verify_command": (meta.get("verify_commands") or ["true"])[0],
        "pii_bound": args.pii_bound,
    }
    challengers = grading.select_challengers(unit, candidates)
    concurrency = grading.concurrency_for_headroom(_live_session_active())
    log(f"selected {len(challengers)} challenger(s); concurrency={concurrency}")

    outcome = grading.grade_replay(
        unit, meta, challengers,
        ledger_path=args.ledger,
        run_fn=_make_run_fn(log),
        verify_fn=_make_verify_fn(bundle_dir, log),
        judge_fn=_make_judge_fn(args.judge_model, log),
        incumbent_first_shot=first_shot,
        spec=spec,
        shape=args.shape,
        base_commit=meta.get("base_commit", "unknown"),
        date=time.strftime("%Y-%m-%d"),
        log_fn=log,
    )
    log(f"wrote {len(outcome.records_written)} field record(s)")
    if outcome.skipped_reason:
        log(f"skip/partial: {outcome.skipped_reason}")
    return 0


def main(argv=None):
    ap = argparse.ArgumentParser(description="Detached bake-off runner.")
    sub = ap.add_subparsers(dest="cmd", required=True)

    pr = sub.add_parser("run", help="replay one bundle against challengers")
    pr.add_argument("bundle_dir")
    pr.add_argument("--ledger", default=str(DEFAULT_LEDGER))
    pr.add_argument("--challengers", help="comma-separated model list override")
    pr.add_argument("--judge-model", dest="judge_model", default="qwen2.5:7b")
    pr.add_argument("--shape", default="batch-extraction (text/json)")
    pr.add_argument("--pii-bound", dest="pii_bound", action="store_true")
    pr.add_argument("--runner-log", dest="runner_log")
    pr.add_argument("--detach", action="store_true")
    pr.set_defaults(func=cmd_run)

    args = ap.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
